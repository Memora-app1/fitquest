# ════════ SUPABASE ════════
# Pegue em: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# 🔒 NUNCA expor — service role tem acesso total ao banco
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ════════ ANTHROPIC (Coach IA) ════════
# Pegue em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ════════ MERCADO PAGO ════════
# Pegue em: https://www.mercadopago.com.br/developers/panel/app
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-...
MERCADO_PAGO_PUBLIC_KEY=APP_USR-...
MERCADO_PAGO_WEBHOOK_SECRET=gera_secret_no_painel_do_mp

# IDs dos planos criados no Mercado Pago
MP_PLAN_MONTHLY_ID=
MP_PLAN_ANNUAL_ID=
# Para o vitalício usamos Checkout Pro (não subscription)

# ════════ GOOGLE OAUTH (Calendário) ════════
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/oauth/callback

# ════════ WEB PUSH (notificações) ════════
# Gere com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:seu@email.com

# ════════ SEGURANÇA ════════
# String aleatória grande — usado para autenticar crons
CRON_SECRET=gera_uma_string_de_64_caracteres_aleatoria_aqui

# ════════ APP ════════
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FitQuest
